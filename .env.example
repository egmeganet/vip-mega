# =============================================
# متغيرات البيئة - MEGA-TIK Finance & Subscribers ERP
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# =============================================

# ---- قاعدة البيانات ----
# رابط اتصال PostgreSQL
# صيغة: postgresql://المستخدم:كلمة_المرور@الخادم:المنفذ/اسم_قاعدة_البيانات
DATABASE_URL=postgresql://postgres:password@localhost:5432/megatik_erp

# ---- السيرفر الخلفي (API Server) ----
PORT=8080
NODE_ENV=development

# مفتاح JWT السري - غيّره لقيمة عشوائية قوية في الإنتاج
JWT_SECRET=megatik-erp-secret-key-change-this-in-production

# ---- الواجهة الأمامية (Frontend) ----
FRONTEND_PORT=3000
# المسار الأساسي - اتركه / للتثبيت المحلي
BASE_PATH=/
